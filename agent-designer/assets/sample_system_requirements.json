{
  "goal": "构建一个综合性的研究与分析平台，能够从多个来源收集信息、分析数据并生成详细报告",
  "description": "系统需要处理涉及网页搜索、数据分析、文档处理和协同报告生成的复杂研究任务。它应当能够协调多个 specialist 并行工作，同时保持质量控制，并确保对研究主题的覆盖足够全面。",
  "tasks": [
    "针对指定主题开展多来源网页研究",
    "分析并综合来自不同来源的信息",
    "执行数据处理和统计分析",
    "基于数据生成可视化和图表",
    "撰写完整的书面报告",
    "对事实进行核查并验证信息准确性",
    "协调并行研究流",
    "处理实时信息更新",
    "管理研究项目时间线"
  ],
  "constraints": {
    "max_response_time": 30000,
    "budget_per_task": 1.0,
    "quality_threshold": 0.9,
    "concurrent_tasks": 10,
    "data_retention_days": 90,
    "security_level": "standard",
    "compliance_requirements": ["GDPR", "data_minimization"]
  },
  "team_size": 6,
  "performance_requirements": {
    "high_throughput": true,
    "fault_tolerance": true,
    "low_latency": false,
    "scalability": "medium",
    "availability": 0.99
  },
  "safety_requirements": [
    "输入校验与清洗",
    "输出内容过滤",
    "外部 API 限流",
    "错误处理与优雅降级",
    "关键决策需要人工监督",
    "为所有操作保留审计日志"
  ],
  "integration_requirements": [
    "为外部系统提供 REST API 接口",
    "支持 Webhook 实现实时更新",
    "集成数据库以持久化数据",
    "提供文档与媒体文件存储",
    "对重要事件发送邮件通知",
    "提供监控与控制面板"
  ],
  "scale_requirements": {
    "initial_users": 50,
    "peak_concurrent_users": 200,
    "data_volume_gb": 100,
    "requests_per_hour": 1000,
    "geographic_regions": ["US", "EU"],
    "growth_projection": "每年增长 50%"
  }
}
